  m_TableData:
  - m_Id: 355724703518720
    m_Localized: Oyna
    m_Metadata:
      m_Items: []
  - m_Id: 355803820675072
    m_Localized: Ayarlar
    m_Metadata:
      m_Items: []
  - m_Id: 355907369652224
    m_Localized: "\u015Eimdi \u0130stek Listesine Ekle!"
    m_Metadata:
      m_Items: []
  - m_Id: 5438005906460672
    m_Localized: "Gizlilik Politikas\u0131"
    m_Metadata:
      m_Items: []
  - m_Id: 5438365886795776
    m_Localized: "Merhaba!\n<b>Game Title oyununu denedi\u011Fin i\xE7in te\u015Fekk\xFCrler!</b>\n\nOyunu
      geli\u015Ftirmemize yard\u0131mc\u0131 olmak i\xE7in <b>anonim</b> oynan\u0131\u015F
      verileri topluyoruz \u2014 \xF6rne\u011Fin b\xF6l\xFCm ilerlemesi, skorlar
      ve hangi mekanikleri kulland\u0131\u011F\u0131n.\n\nBu verileri yaln\u0131zca
      dengeyi, kararl\u0131l\u0131\u011F\u0131 ve genel oyun kalitesini iyile\u015Ftirmek
      i\xE7in kullan\u0131yoruz. <b>Ad\u0131n veya e-postan gibi ki\u015Fisel bilgileri
      toplam\u0131yoruz.</b>\n\nAnaliti\u011Fi Ayarlar\u2019dan istedi\u011Fin zaman
      kapatabilir ve analiz verilerinin silinmesini istedi\u011Fin zaman talep edebilirsin.\nAyr\u0131nt\u0131lar
      i\xE7in l\xFCtfen Gizlilik Politikam\u0131z\u0131 oku."
    m_Metadata:
      m_Items: []
  - m_Id: 5438677955596288
    m_Localized: "Hay\u0131r, te\u015Fekk\xFCrler"
    m_Metadata:
      m_Items: []
  - m_Id: 5437282128973824
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 5437776046018560
    m_Localized: Tamam
    m_Metadata:
      m_Items: []
  - m_Id: 19099382151860224
    m_Localized: "\u2026 erken s\xFCr\xFCm\xFCn\xFC oynad\u0131\u011F\u0131n i\xE7in
      te\u015Fekk\xFCrler!"
    m_Metadata:
      m_Items: []
  - m_Id: 19099473642213376
    m_Localized: "Tam s\xFCr\xFCmde daha fazla i\xE7erik gelecek."
    m_Metadata:
      m_Items: []
  - m_Id: 19108764277231616
    m_Localized: Hata bildir
    m_Metadata:
      m_Items: []
  - m_Id: 19108828471054336
    m_Localized: "Geri bildirim g\xF6nder"
    m_Metadata:
      m_Items: []
  - m_Id: 19114354789535744
    m_Localized: Reddet
    m_Metadata:
      m_Items: []
  - m_Id: 19115665924771840
    m_Localized: Emin misin?
    m_Metadata:
      m_Items: []
  - m_Id: 19139831847669760
    m_Localized: "Ba\u015Far\u0131l\u0131!"
