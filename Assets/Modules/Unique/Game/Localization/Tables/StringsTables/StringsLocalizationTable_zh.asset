  - m_Id: 5438365886795776
    m_Localized: "\u4F60\u597D\uFF01\n\u611F\u8C22\u8BD5\u73A9 Game Title!\n\n\u4E3A\u4E86\u5E2E\u52A9\u6211\u4EEC\u6539\u8FDB\u6E38\u620F\uFF0C\u6211\u4EEC\u4F1A\u6536\u96C6<b>\u533F\u540D</b>\u6E38\u620F\u6570\u636E\u2014\u2014\u4F8B\u5982\u5173\u5361\u8FDB\u5EA6\u3001\u5206\u6570\uFF0C\u4EE5\u53CA\u4F60\u4F7F\u7528\u7684\u6E38\u620F\u673A\u5236\u3002\n\n\u6211\u4EEC\u4EC5\u4F7F\u7528\u8FD9\u4E9B\u6570\u636E\u6765\u6539\u5584\u5E73\u8861\u6027\u3001\u7A33\u5B9A\u6027\u548C\u6574\u4F53\u6E38\u620F\u8D28\u91CF\u3002<b>\u6211\u4EEC\u4E0D\u4F1A\u6536\u96C6\u4F60\u7684\u59D3\u540D\u6216\u90AE\u7BB1\u7B49\u4E2A\u4EBA\u4FE1\u606F\u3002</b>\n\n\u4F60\u53EF\u4EE5\u968F\u65F6\u5728\u8BBE\u7F6E\u4E2D\u5173\u95ED\u6570\u636E\u5206\u6790\uFF0C\u4E5F\u53EF\u4EE5\u968F\u65F6\u8BF7\u6C42\u5220\u9664\u4F60\u7684\u5206\u6790\u6570\u636E\u3002\n\u8BE6\u60C5\u8BF7\u9605\u8BFB\u6211\u4EEC\u7684\u300A\u9690\u79C1\u653F\u7B56\u300B\u3002"
