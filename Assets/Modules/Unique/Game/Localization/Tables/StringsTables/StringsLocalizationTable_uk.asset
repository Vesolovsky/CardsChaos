  - m_Id: 355907369652224
    m_Localized: "\u0414\u043E\u0434\u0430\u0442\u0438 \u0434\u043E \u0441\u043F\u0438\u0441\u043A\u0443
      \u0431\u0430\u0436\u0430\u043D\u044C!"
    m_Metadata:
      m_Items: []
  - m_Id: 5438005906460672
    m_Localized: "\u041F\u043E\u043B\u0456\u0442\u0438\u043A\u0430 \u043A\u043E\u043D\u0444\u0456\u0434\u0435\u043D\u0446\u0456\u0439\u043D\u043E\u0441\u0442\u0456"
    m_Metadata:
      m_Items: []
  - m_Id: 5438365886795776
    m_Localized: "\u041F\u0440\u0438\u0432\u0456\u0442!\n<b>\u0414\u044F\u043A\u0443\u0454\u043C\u043E,
      \u0449\u043E \u0441\u043F\u0440\u043E\u0431\u0443\u0432\u0430\u043B\u0438 Game
      Title!</b>\n\n\u0429\u043E\u0431 \u0434\u043E\u043F\u043E\u043C\u043E\u0433\u0442\u0438
      \u043D\u0430\u043C \u043F\u043E\u043A\u0440\u0430\u0449\u0443\u0432\u0430\u0442\u0438
      \u0433\u0440\u0443, \u043C\u0438 \u0437\u0431\u0438\u0440\u0430\u0454\u043C\u043E
      <b>\u0430\u043D\u043E\u043D\u0456\u043C\u043D\u0456</b> \u0434\u0430\u043D\u0456
      \u043F\u0440\u043E \u0456\u0433\u0440\u043E\u0432\u0438\u0439 \u043F\u0440\u043E\u0446\u0435\u0441
      \u2014 \u043D\u0430\u043F\u0440\u0438\u043A\u043B\u0430\u0434 \u043F\u0440\u043E\u0433\u0440\u0435\u0441
      \u0443 \u0440\u0456\u0432\u043D\u044F\u0445, \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0438
      \u0442\u0430 \u0442\u0435, \u044F\u043A\u0438\u043C\u0438 \u043C\u0435\u0445\u0430\u043D\u0456\u043A\u0430\u043C\u0438
      \u0432\u0438 \u043A\u043E\u0440\u0438\u0441\u0442\u0443\u0454\u0442\u0435\u0441\u044F.\n\n\u041C\u0438
      \u0432\u0438\u043A\u043E\u0440\u0438\u0441\u0442\u043E\u0432\u0443\u0454\u043C\u043E
      \u0446\u0456 \u0434\u0430\u043D\u0456 \u043B\u0438\u0448\u0435 \u0434\u043B\u044F
      \u043F\u043E\u043A\u0440\u0430\u0449\u0435\u043D\u043D\u044F \u0431\u0430\u043B\u0430\u043D\u0441\u0443,
      \u0441\u0442\u0430\u0431\u0456\u043B\u044C\u043D\u043E\u0441\u0442\u0456 \u0442\u0430
      \u0437\u0430\u0433\u0430\u043B\u044C\u043D\u043E\u0457 \u044F\u043A\u043E\u0441\u0442\u0456
      \u0433\u0440\u0438. <b>\u041C\u0438 \u043D\u0435 \u0437\u0431\u0438\u0440\u0430\u0454\u043C\u043E
      \u043E\u0441\u043E\u0431\u0438\u0441\u0442\u0456 \u0434\u0430\u043D\u0456,
      \u044F\u043A-\u043E\u0442 \u0432\u0430\u0448\u0435 \u0456\u043C\u2019\u044F
      \u0447\u0438 \u0435\u043B\u0435\u043A\u0442\u0440\u043E\u043D\u043D\u0443 \u043F\u043E\u0448\u0442\u0443.</b>\n\n\u0412\u0438
      \u043C\u043E\u0436\u0435\u0442\u0435 \u0431\u0443\u0434\u044C-\u043A\u043E\u043B\u0438
      \u0432\u0438\u043C\u043A\u043D\u0443\u0442\u0438 \u0430\u043D\u0430\u043B\u0456\u0442\u0438\u043A\u0443
      \u0432 \u041D\u0430\u043B\u0430\u0448\u0442\u0443\u0432\u0430\u043D\u043D\u044F\u0445
      \u0456 \u0432 \u0431\u0443\u0434\u044C-\u044F\u043A\u0438\u0439 \u043C\u043E\u043C\u0435\u043D\u0442
      \u0437\u0430\u043F\u0440\u043E\u0441\u0438\u0442\u0438 \u0432\u0438\u0434\u0430\u043B\u0435\u043D\u043D\u044F
      \u0432\u0430\u0448\u0438\u0445 \u0430\u043D\u0430\u043B\u0456\u0442\u0438\u0447\u043D\u0438\u0445
      \u0434\u0430\u043D\u0438\u0445.\n\u0414\u0435\u0442\u0430\u043B\u0456 \u2014
      \u0443 \u043D\u0430\u0448\u0456\u0439 \u041F\u043E\u043B\u0456\u0442\u0438\u0446\u0456
      \u043A\u043E\u043D\u0444\u0456\u0434\u0435\u043D\u0446\u0456\u0439\u043D\u043E\u0441\u0442\u0456."
    m_Metadata:
      m_Items: []
